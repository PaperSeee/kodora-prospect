generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Prospect {
  id          Int      @id @default(autoincrement())
  nom         String
  secteur     String
  ville       String   @default("Bruxelles")
  telephone   String?
  email       String?
  siteWeb     String?
  note        Float?
  avis        Int?
  statut      String   @default("a_contacter")
  score       Int      @default(0)
  angle       String?
  goldStar    Boolean  @default(false)

  // Diagnostic stocké en JSON sérialisé
  diagnostic  String?

  // Email généré par IA
  emailObjet  String?
  emailCorps  String?
  emailHtml   String?

  // Notes perso CRM
  notes       String?

  // Tracking ouvertures et relances
  emailOuvert   Boolean   @default(false)
  emailOuvertAt DateTime?
  relancee      Boolean   @default(false)
  relanceeAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  audits      Audit[]
}

model EarlyAccessSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  url       String?
  createdAt DateTime @default(now())
}

// Trace chaque exécution du pipeline auto (source → génère → envoie).
// Sert aussi à compter les envois du jour pour respecter le plafond / ramp.
model PipelineRun {
  id          Int      @id @default(autoincrement())
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  sourced     Int      @default(0)  // nouveaux prospects sourcés
  generated   Int      @default(0)  // emails générés
  sent        Int      @default(0)  // emails réellement envoyés
  capUsed     Int      @default(0)  // plafond appliqué ce jour-là
  status      String   @default("running") // running | done | error
  error       String?
}

model Audit {
  id                   String    @id @default(cuid())
  prospectId           Int
  prospect             Prospect  @relation(fields: [prospectId], references: [id])
  publicSlug           String    @unique
  score                Int
  problemesJson        String    // JSON sérialisé (SQLite pas de Json natif)
  rapportJson          String?   // snapshot complet AuditResult sérialisé
  generatedAt          DateTime  @default(now())
  firstViewedAt        DateTime?
  lastViewedAt         DateTime?
  viewCount            Int       @default(0)
  ctaClicked           Boolean   @default(false)
  ctaClickedAt         DateTime?
  emailCapturedAt      DateTime?
  emailCaptured        String?
}
